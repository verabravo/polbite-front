# ─── Expo Router ───────────────────────────────────────────────────────────────
# Directorio raíz de las rutas de Expo Router (relativo al proyecto)
EXPO_ROUTER_APP_ROOT=src/app

# ─── API ───────────────────────────────────────────────────────────────────────
# URL base del backend de Polbite (sin trailing slash)
# Desarrollo local: http://localhost:8000
# Staging: https://api-staging.polbite.com
# Producción: https://api.polbite.com
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Versión del API (se añade como prefijo: /api/v1/...)
EXPO_PUBLIC_API_VERSION=v1

# Timeout en milisegundos para las peticiones HTTP
EXPO_PUBLIC_API_TIMEOUT=10000

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Nombre de la clave con la que se guarda el access token en SecureStore
EXPO_PUBLIC_SECURE_STORE_TOKEN_KEY=polbite_access_token

# Nombre de la clave del refresh token en SecureStore
EXPO_PUBLIC_SECURE_STORE_REFRESH_KEY=polbite_refresh_token

# ─── App ───────────────────────────────────────────────────────────────────────
# Entorno de ejecución (development | staging | production)
EXPO_PUBLIC_ENV=development

# Habilita logs de red detallados en consola (true | false)
EXPO_PUBLIC_DEBUG_NETWORK=false
